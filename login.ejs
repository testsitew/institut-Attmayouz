<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<title>Connexion Admin - Institut Attamayouz</title>
<style>
  body { font-family: Arial, sans-serif; background: #e9f5eb; display: flex; justify-content:center; align-items:center; height: 100vh; }
  form { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 0 10px #aaa; width: 300px; }
  input { width: 100%; padding: 10px; margin: 10px 0; }
  button { background-color: #155d36; color: white; border: none; padding: 10px; width: 100%; cursor: pointer; font-weight: bold; }
  button:hover { background-color: #134827; }
  .error { color: red; margin-bottom: 10px; }
</style>
</head>
<body>

<form method="POST" action="/admin/login">
  <input type="text" name="username" placeholder="Nom d'utilisateur" required />
  <input type="password" name="password" placeholder="Mot de passe" required />
  <button type="submit">Se connecter</button>
</form>

</body>
</html>
